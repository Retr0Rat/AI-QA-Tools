# Anthropic API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GCP Storage — Service account JSON (paste the entire JSON as a single line)
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# GCP bucket that stores the processed course JSON files
GCP_BUCKET_NAME=dc-ai-program-courses

# Playwright E2E — base URL of the deployed app (or http://localhost:3001 for local)
PLAYWRIGHT_BASE_URL=https://your-app.vercel.app
